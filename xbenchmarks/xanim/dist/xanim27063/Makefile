	xa_set.o xa_cmap.o xa_rle.o xa_wav.o xa_au.o \
	xa_avi.o xa_qt.o xa_qt_decs.o xa_audio.o xa_ipc.o xa_color.o \
	xa_jpg.o xa_mpg.o xa_dl.o xa_jmov.o xa_movi.o \
